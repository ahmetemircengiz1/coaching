generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// SITE MODU — Aşama 2 sadeleştirme
// TEMPLATE: 6 hazır şablondan biri + içerik formları (Basic UI)
// BUILDER:  Section Builder ile sıfırdan kurulum (yalnız Elite paket)
// ============================================
enum SiteMode {
  TEMPLATE
  BUILDER
}

// ============================================
// SaaS PLATFORM - Paketler
// ============================================

model SaasPackage {
  id          String   @id @default(cuid())
  name        String   // "Başlangıç", "Profesyonel", "Premium"
  tier        Int      @unique // 1, 2, 3
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("TRY")
  maxStudents Int      // 5, 10, 999
  features    Json     // Paket özellikleri listesi
  templates   Json     // Kullanılabilir template ID'leri
  isActive    Boolean  @default(true)

  coaches     Coach[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// TENANT (COACH) - Ana tenant entity
// ============================================

model Coach {
  id              String   @id @default(cuid())
  userId          String   @unique // Supabase Auth user ID
  email           String   @unique
  name            String
  brandName       String
  bio             String?
  logo            String?  // Supabase Storage URL
  heroImageOriginalUrl String? @map("hero_image_original_url")
  heroImageDesktopUrl String?  @map("hero_image_desktop_url")
  heroImageMobileUrl  String?  @map("hero_image_mobile_url")
  heroImageBlurDataUrl String? @db.Text @map("hero_image_blur_data_url")
  heroImageCutoutUrl  String?  @map("hero_image_cutout_url")
  heroFocalY      Int      @default(35) @map("hero_focal_y")
  heroFocalX      Int      @default(50) @map("hero_focal_x")
  heroMode        String   @default("photo") @map("hero_mode")
  heroVideoUrl    String?  @map("hero_video_url") // HeroDisplayBold sağ alt notch'unda oynatılır
  subdomain       String   @unique
  customDomain    String?  @unique

  // Branding
  primaryColor    String   @default("#000000")
  secondaryColor  String   @default("#ccff00")
  landingThemeId  Int      @default(1)
  dashboardThemeId Int     @default(1)
  plan            String   @default("starter")
  templateId      String   @default("classic-dark")
  dashboardTemplateId String @default("dark-teal")
  sidebarPosition String   @default("left")

  // Kademe 2: Gelişmiş Kişiselleştirme
  // Aşama 2 sadeleştirme: TEMPLATE (6 şablon) vs BUILDER (Section Builder)
  siteMode        SiteMode @default(TEMPLATE) @map("site_mode")
  landingConfig   Json?    // Bölüm sırası, görünürlük, varyantlar
  eliteConfig     Json?    // Section Builder konfigürasyonu (siteMode=BUILDER kullanır)
  socialLinks     Json?    // { instagram, youtube, tiktok, twitter, facebook, linkedin }
  headingFont     String?  // Google Font ID
  bodyFont        String?  // Google Font ID
  heroImageDark   Boolean? @map("hero_image_dark") // Auto-detected: true = dark hero, false = light
  landingTexts    Json?    @map("landing_texts")   // { heroHeadline, heroSubtitle, ctaPrimaryText, ctaSecondaryText }
  landingFaqs     Json?    @map("landing_faqs")    // [{ id, question, answer }] — Section Builder FAQ blokları için
  aboutText       String?  @db.Text @map("about_text") // Hakkımızda sayfası metni
  whatsappNumber  String?  @map("whatsapp_number") // +905xxxxxxxxx formatında
  dashboardNote   String?  @db.Text @map("dashboard_note") // Koçun ana sayfa yapışkan notu

  // İletişim & Yasal bilgiler (footer + yasal sayfalar için)
  contactPhone    String?  @map("contact_phone")
  businessAddress String?  @db.Text @map("business_address")
  legalFullName   String?  @map("legal_full_name")   // Şahıs firması tam adı / tüzel ünvan
  taxId           String?  @map("tax_id")            // Vergi kimlik no
  legalTexts      Json?    @map("legal_texts")       // { gizlilik, kvkk, mesafeliSatis, iade } markdown içerikleri

  // Abonelik
  packageId       String
  package         SaasPackage @relation(fields: [packageId], references: [id])
  subscriptionStatus String @default("active")
  subscriptionId  String?  // iyzico/stripe subscription ID

  // Coach'un kendi ödeme entegrasyonu
  iyzicoApiKey    String?
  iyzicoSecretKey String?
  stripeAccountId String?

  // İlişkiler
  students          Student[]
  studentInvites    StudentInvite[]
  registrationCodes CoachRegistrationCode[]
  coachPackages     CoachPackage[]
  programs          Program[]
  exercises         Exercise[]
  transformations   Transformation[]
  testimonials      Testimonial[]
  nutritionPlans    NutritionPlan[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subdomain])
  @@index([customDomain])
}

// ============================================
// COACH'UN KENDİ PAKETLERİ
// ============================================

model CoachPackage {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name        String
  description String   @db.Text
  duration    Int      // Hafta sayısı
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("TRY")
  features    Json     // Paket içerikleri
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)

  students          Student[]
  studentInvites    StudentInvite[]
  registrationCodes CoachRegistrationCode[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coachId])
}

// ============================================
// KAYIT KODU (koç üretir, öğrenci kayıt sırasında kullanır, tek-kullanımlık)
// ============================================

model CoachRegistrationCode {
  id                String        @id @default(cuid())
  coachId           String
  coach             Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  code              String        @unique
  label             String?
  coachPackageId    String?
  coachPackage      CoachPackage? @relation(fields: [coachPackageId], references: [id], onDelete: SetNull)
  usedAt            DateTime?
  usedByStudentId   String?
  revokedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())

  @@index([coachId])
  @@index([code])
}

// ============================================
// ÖĞRENCİ DAVETLERİ (tek-kullanımlık token)
// ============================================

model StudentInvite {
  id               String        @id @default(cuid())
  coachId          String
  coach            Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  token            String        @unique
  email            String
  name             String
  coachPackageId   String?
  coachPackage     CoachPackage? @relation(fields: [coachPackageId], references: [id], onDelete: SetNull)
  expiresAt        DateTime
  claimedAt        DateTime?
  claimedStudentId String?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())

  @@index([coachId])
  @@index([email, coachId])
}

// ============================================
// ÖĞRENCİ
// ============================================

model Student {
  id              String   @id @default(cuid())
  userId          String   @unique // Supabase Auth user ID
  email           String
  name            String
  phone           String?
  avatar          String?

  coachId         String
  coach           Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  coachPackageId  String?
  coachPackage    CoachPackage? @relation(fields: [coachPackageId], references: [id])

  status          String   @default("active")
  startDate       DateTime @default(now())
  endDate         DateTime?

  // Dashboard ayarları
  dashboardThemeId Int     @default(1)
  sidebarPosition  String  @default("bottom")
  coachNotes       String? @db.Text
  notificationPrefs Json?  // { programAssigned: bool, feedbackReceived: bool, messageReceived: bool }

  // İlişkiler
  trainingPlans   TrainingPlan[]
  nutritionPlans  NutritionPlan[]
  checkIns        WeeklyCheckIn[]
  metrics         Metric[]
  workoutAttendances WorkoutAttendance[]
  mealEntries     MealEntry[]
  exerciseLogs    ExerciseLog[]
  mealCompletions MealCompletion[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([coachId])
}

// ============================================
// HAFTALIK SPOR DEVAM TAKVİMİ
// (öğrenci günlük tek-tık attendance log'u)
// ============================================

model WorkoutAttendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date         // sadece tarih (TZ-naive)
  attended  Boolean  @default(true)
  note      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([studentId, date])
}

// ============================================
// GÜNLÜK YEMEK LOG'U
// (öğrenci öğün başına foto + opsiyonel not yükler)
// ============================================

model MealEntry {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  date         DateTime @db.Date          // sadece tarih
  mealType     String                     // "breakfast" | "lunch" | "dinner" | "snack"
  photoUrl     String
  note         String?  @db.Text          // öğrencinin notu
  coachComment String?  @db.Text          // koç yorumu (Faz 3)
  eatenAt      DateTime?                  // öğün saati (opsiyonel)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId, date])
  @@index([studentId, mealType])
}

// ============================================
// EGZERSİZ KÜTÜPHANESİ
// ============================================

model Exercise {
  id          String   @id @default(cuid())
  coachId     String?
  coach       Coach?   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name        String
  category    String
  imageUrl    String?
  description String?  @db.Text
  isSystem    Boolean  @default(false) // true = hazır egzersiz, false = koç ekledi

  workoutExercises WorkoutExercise[]
  asAlternativeFor WorkoutExerciseAlternative[] @relation("WorkoutExerciseAlternativeFor")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coachId])
  @@index([category])
  @@index([isSystem])
}

// ============================================
// PROGRAM ŞABLONLARI
// ============================================

model Program {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  weeks       Int
  isTemplate  Boolean  @default(true)

  workouts    ProgramWorkout[]
  trainingPlans TrainingPlan[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coachId])
}

model ProgramWorkout {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 1-7
  weekNumber  Int
  name        String

  exercises   WorkoutExercise[]

  @@index([programId])
}

model WorkoutExercise {
  id              String         @id @default(cuid())
  workoutId       String
  workout         ProgramWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise       @relation(fields: [exerciseId], references: [id])
  sets            Int
  reps            String         // "8-12" veya "AMRAP"
  restSeconds     Int?
  notes           String?
  orderIndex      Int

  // Öğrenci günlük logları (her gün için 1 kayıt)
  logs            ExerciseLog[]

  // Koçun tanımladığı alternatif egzersizler
  alternatives    WorkoutExerciseAlternative[]

  @@index([workoutId])
}

// Koçun bir egzersiz için tanımladığı alternatif(ler). Öğrenci sıkıştığında
// bu alternatiflerden seçim yapabilir.
model WorkoutExerciseAlternative {
  id                    String          @id @default(cuid())
  workoutExerciseId     String
  workoutExercise       WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  alternativeExerciseId String
  alternativeExercise   Exercise        @relation("WorkoutExerciseAlternativeFor", fields: [alternativeExerciseId], references: [id], onDelete: Cascade)
  orderIndex            Int             @default(0)

  @@unique([workoutExerciseId, alternativeExerciseId])
  @@index([workoutExerciseId])
}

// Öğrencinin günlük egzersiz logu (yaptım + opsiyonel detay)
model ExerciseLog {
  id                  String           @id @default(cuid())
  studentId           String
  student             Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workoutExerciseId   String
  workoutExercise     WorkoutExercise  @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  date                DateTime         @default(now()) @db.Date
  setsCompleted       Int?
  repsCompleted       String?          // "10,8,6" gibi set başına farklı tekrar
  weightUsed          Decimal?         @db.Decimal(6, 2)
  notes               String?          @db.Text
  alternativeUsed     String?          // öğrenci alternatif egzersize geçtiyse adı
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([studentId, workoutExerciseId, date])
  @@index([studentId, date])
}

// ============================================
// ANTRENMAN PLANI VE LOG
// ============================================

model TrainingPlan {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  programId   String?
  program     Program? @relation(fields: [programId], references: [id])
  name        String
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("active")

  dailyLogs   TrainingLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
}

model TrainingLog {
  id              String       @id @default(cuid())
  trainingPlanId  String
  trainingPlan    TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  date            DateTime
  completed       Boolean      @default(false)
  exercises       Json         // [{exerciseId, sets: [{reps, weight, completed}]}]
  notes           String?      @db.Text
  coachFeedback   String?      @db.Text

  createdAt       DateTime     @default(now())

  @@index([trainingPlanId])
  @@index([date])
}

// ============================================
// BESLENME PLANI
// ============================================

model NutritionPlan {
  id              String   @id @default(cuid())
  coachId         String?
  coach           Coach?   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  studentId       String?
  student         Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sourceNutritionPlanId String?
  sourceNutritionPlan   NutritionPlan?  @relation("NutritionPlanClones", fields: [sourceNutritionPlanId], references: [id], onDelete: SetNull)
  assignedPlans         NutritionPlan[] @relation("NutritionPlanClones")
  name            String
  startDate       DateTime?
  status          String   @default("active")
  targetCalories  Int?
  targetProtein   Int?
  targetCarbs     Int?
  targetFat       Int?
  coachNotes      String?  @db.Text
  supplements     Json?

  meals           Meal[]
  dailyLogs       NutritionLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([coachId])
}

model Meal {
  id              String        @id @default(cuid())
  nutritionPlanId String
  nutritionPlan   NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
  name            String
  time            String?
  foods           Json          // [{name, portion, calories, protein, carbs, fat}]
  alternatives    Json?         // string[] — koçun tanımladığı alternatif öğünler (ör: "Omlet + ekmek")
  orderIndex      Int

  // Öğrenci öğün tamamlama kayıtları
  completions     MealCompletion[]

  @@index([nutritionPlanId])
}

// Öğrencinin günlük öğün durumu (yedim/yemedim)
model MealCompletion {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mealId          String
  meal            Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  date            DateTime @default(now()) @db.Date
  completed       Boolean  @default(true)
  notes           String?  @db.Text
  alternativeUsed String?  // öğrenci alternatif öğünü yediyse adı/metni
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([studentId, mealId, date])
  @@index([studentId, date])
}

model NutritionLog {
  id              String        @id @default(cuid())
  nutritionPlanId String
  nutritionPlan   NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
  date            DateTime
  meals           Json
  totalCalories   Int?
  totalProtein    Int?
  totalCarbs      Int?
  totalFat        Int?
  mealPhotos      String[]
  notes           String?       @db.Text

  createdAt       DateTime      @default(now())

  @@index([nutritionPlanId])
  @@index([date])
}

// ============================================
// HAFTALIK KONTROL
// ============================================

model WeeklyCheckIn {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekNumber  Int
  date        DateTime @default(now())

  // Ölçümler
  weight      Decimal? @db.Decimal(5, 2)
  bodyFat     Decimal? @db.Decimal(4, 1)
  chest       Decimal? @db.Decimal(5, 1)
  waist       Decimal? @db.Decimal(5, 1)
  hips        Decimal? @db.Decimal(5, 1)
  arms        Decimal? @db.Decimal(5, 1)
  thighs      Decimal? @db.Decimal(5, 1)

  // Fotoğraflar
  frontPhoto  String?
  sidePhoto   String?
  backPhoto   String?
  photos      String[]

  // Genel durum
  energyLevel     Int?
  sleepQuality    Int?
  stressLevel     Int?
  compliance      Int?
  notes           String?  @db.Text
  coachFeedback   String?  @db.Text

  // Koç bu check-in'i ana sayfadan gördü mü? (null = okunmamış)
  coachViewedAt   DateTime? @map("coach_viewed_at")

  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([date])
  @@index([coachViewedAt])
}

// ============================================
// METRİKLER
// ============================================

model Metric {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        String   // weight, bodyFat, benchPress1RM, squat1RM, custom
  name        String
  value       Decimal  @db.Decimal(10, 2)
  unit        String   // kg, %, cm
  date        DateTime @default(now())

  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([type])
  @@index([date])
}

// ============================================
// DÖNÜŞÜM HİKAYELERİ
// ============================================

model Transformation {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clientName  String
  description String?  @db.Text
  beforePhoto String
  afterPhoto  String
  duration    String?  // "12 hafta", "6 ay"
  // Faz 2: Dönüşüm blokları için opsiyonel ölçüm bilgileri (koç panelinden girilebilir)
  age           String?  // "35"
  role          String?  // "Memur", "Öğretmen" vb. meslek/rol
  weightBefore  String?  // "95 kg"
  weightAfter   String?  // "74 kg"
  bodyFatBefore String?  // "%40"
  bodyFatAfter  String?  // "%30"
  // Faz 2.5: Koçun isteğine göre özel istatistikler — [{ label, value }, ...]
  // Örn: [{ label: "Squat 1RM", value: "120kg → 165kg" }]
  customStats   Json?    @map("custom_stats")
  isPublished Boolean  @default(true)
  orderIndex  Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([coachId])
}

// ============================================
// ÖĞRENCİ YORUMLARI (TESTIMONIALS)
// ============================================

model Testimonial {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clientName  String
  role        String?  // "Yazılımcı", "Online Danışan" vb. meslek/rol
  quote       String   @db.Text  // yorum metni — koç panelinden girilir
  rating      Int?     // 1-5 yıldız (opsiyonel; bazı tasarımlar gösterir)
  avatar      String?  // danışan fotoğrafı (opsiyonel)
  isPublished Boolean  @default(true)
  orderIndex  Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([coachId])
}

// ============================================
// BİLDİRİMLER
// ============================================

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  type        String   // "check_in" | "program_assigned" | "nutrition_assigned" | "feedback"
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
}

// ============================================
// ÖDEMELER
// ============================================

model Payment {
  id                String   @id @default(cuid())
  type              String   // "saas_subscription" | "coach_payment"
  payerId           String
  receiverId        String
  amount            Decimal  @db.Decimal(10, 2)
  currency          String
  status            String   @default("pending")
  provider          String   // "iyzico" | "stripe"
  providerPaymentId String?
  metadata          Json?

  createdAt         DateTime @default(now())

  @@index([payerId])
  @@index([receiverId])
  @@index([status])
}
