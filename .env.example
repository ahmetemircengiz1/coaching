# ============================================
# Shred - Environment Variables
# ============================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# UNUTMAYIN: .env.local dosyası hem kök dizine hem apps/web/ dizinine gereklidir.
#
# Production deploy notları aşağıda her bölümün başında.

# ─────────────────────────────────────────────
# Supabase (ZORUNLU)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Database (ZORUNLU)
# Production'da pooler URL kullanın (port 6543 transaction, 5432 session)
# ─────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─────────────────────────────────────────────
# Ödeme — iyzico
# Production: IYZICO_BASE_URL=https://api.iyzipay.com
# Sandbox: https://sandbox-api.iyzipay.com
# ─────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─────────────────────────────────────────────
# Ödeme — Stripe (opsiyonel, sadece Stripe kullanılıyorsa)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────
# App URL & Domain (ZORUNLU — production'da gerçek domain)
# Lokal: http://localhost:3002 | Production: https://yourdomain.com
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_DOMAIN=localhost:3002

# ─────────────────────────────────────────────
# Admin (production'da ZORUNLU — virgülle ayrılmış liste)
# Boş bırakılırsa kimse admin paneline erişemez
# ─────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com

# ─────────────────────────────────────────────
# Email — Resend (production'da ZORUNLU)
# Boşsa email göndermez (dev'de log'lar).
# RESEND_FROM: verified domain'inizden bir adres.
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=Shred <noreply@shred.com.tr>

# ─────────────────────────────────────────────
# Analytics — Google Analytics 4 (opsiyonel)
# Boşsa GA script yüklenmez.
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─────────────────────────────────────────────
# Hata İzleme — Sentry (production'da önerilir)
# DSN boşsa Sentry init no-op (hata yakalanmaz).
# SENTRY_AUTH_TOKEN sadece build sırasında source map upload için.
# ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─────────────────────────────────────────────
# Cron (production'da ZORUNLU — Vercel Cron koruması)
# api/cron/* route'ları bu secret olmadan production'da çalışmaz.
# Güçlü rastgele bir değer üretin (ör. openssl rand -hex 32).
# Vercel Cron çağrılarına otomatik Authorization: Bearer <CRON_SECRET> ekler.
# ─────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────
# Rate Limiting (opsiyonel — varsayılan in-memory)
# Multi-region production için Upstash Redis önerilir.
# Boşsa: in-memory rate limit (tek instance'da çalışır).
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────
# Vercel (custom domain yönetimi için — opsiyonel)
# Sadece dashboard'dan domain ekleme akışı kullanılacaksa.
# ─────────────────────────────────────────────
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_AUTH_TOKEN=
