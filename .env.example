# ============================================
# Coach OS - Environment Variables
# ============================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# UNUTMAYIN: .env.local dosyası hem kök dizine hem apps/web/ dizinine gereklidir.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase PostgreSQL via connection pooler)
DATABASE_URL=
DIRECT_URL=

# iyzico (Ödeme)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe (Ödeme)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Vercel (domain yönetimi için)
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_AUTH_TOKEN=
